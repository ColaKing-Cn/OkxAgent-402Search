[Unit]
Description=OpenClaw Management Backend
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/openclaw-backend
EnvironmentFile=/opt/openclaw-backend/.env
ExecStart=/usr/bin/python3 -m uvicorn app:app --host 0.0.0.0 --port 8999
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
